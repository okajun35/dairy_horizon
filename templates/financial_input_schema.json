{
  "schema_id": "dairy_financial_inputs_v2",
  "canonical_units": {
    "milk_price": "yen_per_kg",
    "energy_price": "yen_per_kwh",
    "money": "yen",
    "duration": "years_or_days_as_named"
  },
  "milk_price": {
    "field": "milk_price_yen_per_kg",
    "input_type": "number",
    "min": 0,
    "max": 300,
    "step": 1,
    "default": 135,
    "display_units": [
      "yen_per_kg",
      "yen_per_litre"
    ],
    "milk_density_kg_per_litre": 1.032,
    "density_source_kind": "demo_conversion_assumption",
    "conversion": {
      "yen_per_litre": "yen_per_kg * milk_density_kg_per_litre",
      "yen_per_kg": "yen_per_litre / milk_density_kg_per_litre"
    },
    "change_control": {
      "field": "milk_price_change_yen_per_kg",
      "min": -100,
      "max": 100,
      "step": 1,
      "default": 0,
      "formula": "effective_milk_price = max(0, base_milk_price + milk_price_change)"
    },
    "zero_handling": "At zero, break-even milk volume is undefined; return status='recovery_impossible_at_zero_price'."
  },
  "variable_cost_ratio_pct": {
    "min": 0,
    "max": 99.9,
    "step": 0.1,
    "default": 60.0,
    "note": "The Zenrakuren example uses the milk-feed ratio as a proxy. Sales commission and transport can be added where appropriate."
  },
  "consumption_tax": {
    "rate_pct": {
      "min": 0,
      "max": 20,
      "step": 0.1,
      "default": 10.0
    },
    "tax_basis": {
      "allowed": [
        "tax_exclusive",
        "tax_inclusive"
      ],
      "default": "tax_exclusive"
    },
    "apply_automatically_to_core_formula": false,
    "reason": "The source instructs users to use either tax-exclusive or tax-inclusive values consistently. Tax treatment differs by transaction and business status, so the core formula does not apply a blanket tax transformation."
  },
  "fan_investment": {
    "fan_body_yen_per_unit": {
      "min": 0,
      "max": 2000000,
      "default": 100000
    },
    "inverter_yen_per_unit": {
      "min": 0,
      "max": 1000000,
      "default": 10000
    },
    "installation_yen_per_unit": {
      "min": 0,
      "max": 2000000,
      "default": 110000
    },
    "rated_power_kw": {
      "min": 0,
      "max": 20,
      "default": 0.4
    },
    "cows_covered_per_fan": {
      "min": 1,
      "max": 20,
      "default": 3
    }
  },
  "operation": {
    "energy_charge_yen_per_kwh": {
      "min": 0,
      "max": 200,
      "default": 27
    },
    "basic_charge_yen_per_kw_month": {
      "min": 0,
      "max": 20000,
      "default": 1300
    },
    "hours_per_day": {
      "min": 0,
      "max": 24,
      "default": 24
    },
    "active_days": {
      "min": 1,
      "max": 366,
      "default": 120
    },
    "inverter_reduction_ratio_pct": {
      "min": 0,
      "max": 100,
      "default": 25
    }
  },
  "finance": {
    "useful_life_years": {
      "min": 1,
      "max": 30,
      "default": 7
    },
    "annual_interest_rate_pct": {
      "min": 0,
      "max": 30,
      "default": 0
    },
    "annualisation_method": {
      "allowed": [
        "straight_line",
        "capital_recovery_factor"
      ],
      "default": "straight_line"
    }
  }
}
